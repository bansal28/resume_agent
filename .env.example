# Copy this file to ".env" and fill in your values, or export them in your shell.

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=replace-with-your-telegram-token

# Optional: lock the bot to one Telegram account.
# Message @userinfobot to get your numeric user ID.
# Leave blank to let anyone who finds the bot use it.
ALLOWED_USER_ID=

# AI provider: "anthropic" or "openai".
LLM_PROVIDER=anthropic

# Required when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key

# Required when LLM_PROVIDER=openai.
OPENAI_API_KEY=replace-with-your-openai-api-key

# Optional: pin a specific model.
# Leave blank to use the provider default in analyzer.py.
# LLM_MODEL=
